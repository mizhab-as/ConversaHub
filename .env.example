# ─────────────────────────────────────────────────────────────
# ConversaHub — Root Environment Variables Example
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below
#   3. Never commit your actual .env file to git!
# ─────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────
ENVIRONMENT=development   # development | production

# ─── Security ────────────────────────────────────────────────
# Generate a strong key with: openssl rand -hex 32
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32

# ─── Database ─────────────────────────────────────────────────
# For local development, the default SQLite file is used automatically.
# For production with Docker, switch to postgres:
DATABASE_PROVIDER=sqlite     # sqlite | postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=conversahub_db
POSTGRES_USER=conversahub
POSTGRES_PASSWORD=conversahub_password

# ─── Cache (Redis) ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── AI / LLM ─────────────────────────────────────────────────
# Required for production AI agent responses.
# Get your free key at: https://aistudio.google.com/app/apikey
# Leave EMPTY to fall back to the built-in MockLLM (for local dev/testing).
GEMINI_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
BACKEND_CORS_ORIGINS=http://localhost:3000

# ─── Frontend (Next.js) ───────────────────────────────────────
# Points the frontend to your FastAPI backend server
NEXT_PUBLIC_API_URL=http://localhost:8000
