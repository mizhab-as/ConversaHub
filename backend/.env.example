# General API Configuration
PROJECT_NAME=ConversaHub
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:3000

# Security & JWT Configuration
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=change_me_to_a_secure_random_key_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
DATABASE_PROVIDER=sqlite  # Set to "postgres" to use PostgreSQL in production
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=conversahub
POSTGRES_PASSWORD=conversahub_password
POSTGRES_DB=conversahub_db

# Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Models API Keys (Phase 3)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# LangSmith Observability
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=conversahub-agent

