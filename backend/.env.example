# ConversaHub — Backend Environment (Production)

ENVIRONMENT=production

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# Railway provides this automatically when you add PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Gemini AI Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Your Vercel frontend URL (add after deploying frontend)
BACKEND_CORS_ORIGINS=https://your-app.vercel.app

# Token settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
